# Contact form email delivery (see api/contact.js).
# Set real values only in the host environment (Vercel project settings).
# Never commit a real .env file.

RESEND_API_KEY=<resend api key>
CONTACT_TO_EMAIL=<inbox that receives submissions, e.g. stackcorp7@gmail.com>
CONTACT_FROM_EMAIL=<verified sender address for your Resend domain>
