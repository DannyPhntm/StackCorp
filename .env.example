# Contact form email delivery (see api/contact.js).
# Set real values only in the host environment (Vercel project settings).
# Never commit a real .env file.

RESEND_API_KEY=<resend api key>
CONTACT_TO_EMAIL=<inbox that receives submissions, e.g. stackcorp7@gmail.com>
CONTACT_FROM_EMAIL=<verified sender address for your Resend domain>

# Live Malir Cantt Bazaar case-study stats (see api/mcb-stats.js).
# Both are optional and have safe defaults; neither is a secret.
# MCB_STATS_URL         - server-side upstream stats endpoint override
# VITE_MCB_STATS_URL    - frontend stats URL override (defaults to /api/mcb-stats)
MCB_STATS_URL=<upstream public stats endpoint, defaults to production>
VITE_MCB_STATS_URL=<stats url for the frontend, defaults to /api/mcb-stats>
